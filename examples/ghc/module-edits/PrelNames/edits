# GHC 9.10: skip unsupported modules
skip module GHC.Builtin.Uniques
skip module GHC.Types.Name.Reader

# Axiomatize the whole module — it's hundreds of Unique key definitions
# that all depend on GHC.Builtin.Uniques
axiomatize module PrelNames

# Skip pattern-binding definitions that can't be axiomatized
skip PrelNames.liftedRepDataConKey
skip PrelNames.runtimeRepSimpleDataConKeys

# infinite list of Strings
axiomatize definition PrelNames.allNameStrings

# RdrName type is not translated
add PrelNames Axiom PrelNames.RdrName : Type.
rename type GHC.Types.Name.Reader.RdrName = PrelNames.RdrName
add PrelNames Axiom PrelNames.nameRdrName : Name.Name -> PrelNames.RdrName.
rename value GHC.Types.Name.Reader.nameRdrName = PrelNames.nameRdrName
