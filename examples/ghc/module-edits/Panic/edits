axiomatize module Panic

# GHC 9.10: panic/pgmError moved to GHC.Utils.Panic.Plain, need axioms
add Panic Axiom Panic.panic : forall {a} `{HsToRocq.Err.Default a}, GHC.Base.String -> a.
add Panic Axiom Panic.pgmError : forall {a} `{HsToRocq.Err.Default a}, GHC.Base.String -> a.
add Panic Axiom Panic.someSDoc : GHC.Base.String.

# Ensure pgmError/panic are defined before warnPprTrace uses them
order Panic.panic Panic.panicked
order Panic.pgmError Panic.warnPprTrace
add Panic Axiom Panic.noString : forall {a}, a -> GHC.Base.String.
add Panic Axiom Panic.panicStr : forall {a} `{HsToRocq.Err.Default a}, GHC.Base.String -> (GHC.Base.String -> a).
# assertPprPanic is now generated by axiomatize module (with HasDebugCallStack constraint)
add Panic Definition Panic.warnPprTrace : forall {a}`{HsToRocq.Err.Default a}, bool -> (GHC.Base.String -> (GHC.Num.Integer -> (GHC.Base.String -> (a -> a))))
:= fun {a} {_} b msg i msg2 x => if b then (pgmError msg: a) else x.


add Panic Inductive Panic.panicked {a} : a -> Prop :=
 | PlainPanic `{HsToRocq.Err.Default a} {s}     : panicked (Panic.panic s)
 | StrPanic   `{HsToRocq.Err.Default a} {s} {d} : panicked (Panic.panicStr s d).

skip Panic.withSignalHandlers
skip Panic.tryMost
skip Panic.signalHandlersRefCount
skip Panic.showException
skip Panic.safeShowException
skip Panic.handleGhcException
skip Panic.throwGhcExceptionIO
skip Panic.showGhcException
skip Panic.showGhcExceptionUnsafe

# GHC 9.10: these use HasCallStack/CallStack types
skip Panic.callStackDoc
skip Panic.prettyCallStackDoc

set type Panic.throwGhcException: forall {a}`{HsToRocq.Err.Default a}, GhcException -> a

set type Panic.sorryDoc : forall {a}`{HsToRocq.Err.Default a}, GHC.Base.String -> (GHC.Base.String -> a)

set type Panic.sorry : forall {a}`{HsToRocq.Err.Default a}, GHC.Base.String -> a

set type Panic.pgmErrorDoc : forall {a}`{HsToRocq.Err.Default a}, GHC.Base.String -> (GHC.Base.String -> a)

set type Panic.pgmError : forall {a}`{HsToRocq.Err.Default a}, GHC.Base.String -> a

set type Panic.panicDoc : forall {a}`{HsToRocq.Err.Default a}, GHC.Base.String -> (GHC.Base.String -> a)

set type Panic.panic : forall {a}`{HsToRocq.Err.Default a}, GHC.Base.String -> a

set type Panic.assertPanic : forall {a}`{HsToRocq.Err.Default a}, GHC.Base.String -> (GHC.Num.Int -> a)
