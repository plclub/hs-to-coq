# extendIdSubstWithClone: GHC uses tyCoVarsOfType, varToCoreExpr (not available)
redefine Definition CoreSubst.extendIdSubstWithClone (s : Core.Subst) (v1 v2 : Id) : Core.Subst := match s with | Core.Mk_Subst in_scope ids _ _ => Core.Mk_Subst in_scope (extendVarEnv ids v1 (Core.Mk_Var v2)) tt tt end.

# extendSubst: GHC calls extendTvSubst/extendCvSubst (not available for unit TvSubstEnv)
redefine Definition CoreSubst.extendSubst (s : Core.Subst) (v : Var) (arg : CoreArg) : Core.Subst := match arg with | Core.Mk_Type _ => s | Core.Mk_Coercion _ => s | _ => CoreSubst.extendIdSubst s v arg end.

# extendSubstWithVar: GHC calls mkTyVarTy/mkCoVarCo (not available)
redefine Definition CoreSubst.extendSubstWithVar (s : Core.Subst) (v1 v2 : Var) : Core.Subst := CoreSubst.extendIdSubst s v1 (Core.Mk_Var v2).

