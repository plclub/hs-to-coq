# delBndr: GHC calls delVarEnv on tvs/cvs (unit types)
redefine Definition CoreSubst.delBndr (s : Core.Subst) (v : Var) : Core.Subst := Core.Mk_Subst (CoreSubst.substInScope s) (delVarEnv (CoreSubst.substIdEnv s) v) tt tt.

# delBndrs: same issue
redefine Definition CoreSubst.delBndrs (s : Core.Subst) (vs : list Var) : Core.Subst := Core.Mk_Subst (CoreSubst.substInScope s) (delVarEnvList (CoreSubst.substIdEnv s) vs) tt tt.

