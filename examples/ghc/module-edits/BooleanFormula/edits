# GHC 9.10: skip unsupported modules
skip module GHC.Parser.Annotation

# GHC 9.10: BooleanFormula uses LocatedL (GHC.Parser.Annotation) instead of Located (SrcLoc)
# Redefine to use SrcLoc.Located as a simplification
redefine Inductive BooleanFormula.BooleanFormula (a : Type) : Type := | Var : a -> BooleanFormula a | And : list (SrcLoc.GenLocated SrcLoc.SrcSpan (BooleanFormula a)) -> BooleanFormula a | Or : list (SrcLoc.GenLocated SrcLoc.SrcSpan (BooleanFormula a)) -> BooleanFormula a | Parens : SrcLoc.GenLocated SrcLoc.SrcSpan (BooleanFormula a) -> BooleanFormula a.

redefine Definition BooleanFormula.LBooleanFormula := fun a_ => SrcLoc.GenLocated SrcLoc.SrcSpan (BooleanFormula a_).
order BooleanFormula.BooleanFormula BooleanFormula.LBooleanFormula

skip BooleanFormula.pprBooleanFormula'
skip BooleanFormula.pprBooleanFormula
skip BooleanFormula.pprBooleanFormulaNice
skip BooleanFormula.pprBooleanFormulaNormal

in BooleanFormula.implies termination go deferred

redefine Local Definition BooleanFormula.Functor__BooleanFormula_fmap {a} {b} :
	(a -> b) -> ((BooleanFormula a) -> (BooleanFormula b))
	:= BooleanFormula_fmap.

redefine Local Definition BooleanFormula.Functor__BooleanFormula_op_zlzd__ {a} {b} : a -> ((BooleanFormula b) -> (BooleanFormula a)) := bf_op_zlzd.

redefine Local Definition BooleanFormula.Traversable__BooleanFormula_traverse
    {f} {a} {b} `{_:GHC.Base.Applicative f}: (a -> (f b)) ->
	 ((BooleanFormula a) -> (f (BooleanFormula b)))
    := BooleanFormula_traverse.

redefine Local Definition BooleanFormula.Foldable__BooleanFormula_foldMap
    {m} {a} `{_:GHC.Base.Monoid m}: (a -> m) -> ((BooleanFormula a) -> m)
	 := BooleanFormula_foldMap.

redefine Local Definition BooleanFormula.Foldable__BooleanFormula_foldr
    {a} {b} : (a -> (b -> b)) -> (b -> ((BooleanFormula a) -> b))
	 := BooleanFormula_foldr.


# hs-to-rocq gets the method operations all wrong - defined in midamble
redefine Local Definition BooleanFormula.Foldable__BooleanFormula_null {a} : (BooleanFormula a) -> bool := bf_null.

# GHC 9.10: inner polymorphic let binding in mkAnd/mkOr can't be inferred
axiomatize definition BooleanFormula.mkAnd
axiomatize definition BooleanFormula.mkOr

## defined in the midamble
skip Eq___BooleanFormula


order instance BooleanFormula.Functor__BooleanFormula BooleanFormula.Traversable__BooleanFormula
