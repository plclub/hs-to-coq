# envFor cross-type limitation: OccEnv is a newtype over FastStringEnv (UniqFM NameSpace a),
# so <$ needs GHC.Base.fmap for the inner type, not the local Functor__OccEnv_fmap.
redefine Local Definition OccName.Functor__OccEnv_op_zlzd__ {a} {b} : a -> OccEnv b -> OccEnv a := fun z arg => match arg with | MkOccEnv a1 => MkOccEnv (GHC.Base.fmap (fun b1 => GHC.Base.op_zlzd__ z b1) a1) end.

