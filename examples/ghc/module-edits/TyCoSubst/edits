# GHC.Core.TyCo.Subst — merged into Core.v for concrete Subst type
#
# We keep the Subst data type and type aliases (IdSubstEnv, TvSubstEnv, CvSubstEnv).
# All functions are skipped — type/coercion substitution is identity (axiomatized),
# and Id substitution functions are provided by CoreSubst midamble.

# Coq 8.20: type and constructor cannot share the same name
rename value GHC.Core.TyCo.Subst.Subst = Core.Mk_Subst

# Types/coercions are axiomatized — their SubstEnvs are unit
redefine Definition Core.TvSubstEnv := unit.
redefine Definition Core.CvSubstEnv := unit.

# Skip imports for modules not in the CORESYN group
# (GHC.Core.Type, GHC.Core.Coercion, GHC.Core.TyCo.Rep are in CORESYN — don't skip)
skip module GHC.Core.TyCo.Ppr
skip module GHC.Core.Ppr
skip module GHC.Core.TyCo.FVs

# Skip all functions — provided by CoreSubst midamble or not needed
skip Core.emptyIdSubstEnv
skip Core.emptyTvSubstEnv
skip Core.emptyCvSubstEnv
skip Core.composeTCvSubst
# Default instance for Subst (needed by Err.error calls)
add Core Instance Core.Default__Subst : HsToCoq.Err.Default Core.Subst :=
  HsToCoq.Err.Build_Default _ (Core.Mk_Subst (Core.InScope Core.emptyVarSet) Core.emptyVarEnv tt tt).
order Core.Default__Subst Core.emptySubst

# emptySubst and mkEmptySubst: redefined since their helpers are skipped
redefine Definition Core.emptySubst : Core.Subst := Core.Mk_Subst Core.emptyInScopeSet Core.emptyVarEnv tt tt.
redefine Definition Core.mkEmptySubst (in_scope : Core.InScopeSet) : Core.Subst := Core.Mk_Subst in_scope Core.emptyVarEnv tt tt.
