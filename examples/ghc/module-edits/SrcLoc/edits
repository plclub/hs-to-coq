# GHC 9.10: LexicalFastString newtype constructor in patterns/expressions
# Since LexicalFastString = FastString in Coq, strip the constructor
redefine Definition SrcLoc.mkRealSrcLoc : FastString.FastString -> GHC.Num.Int -> GHC.Num.Int -> RealSrcLoc := fun x line col => ASrcLoc x line col.
redefine Definition SrcLoc.srcLocFile : RealSrcLoc -> FastString.FastString := fun loc => match loc with | ASrcLoc fname _ _ => fname end.
redefine Definition SrcLoc.realSrcLocSpan : RealSrcLoc -> RealSrcSpan := fun loc => match loc with | ASrcLoc file line col => RealSrcSpan' file line col line col end.

