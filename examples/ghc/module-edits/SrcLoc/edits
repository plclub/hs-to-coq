# Auto-generated Default instances come before midamble and need Default RealSrcSpan
# which is in midamble. Skip them and define in midamble instead.
skip SrcLoc.Default__PsSpan
skip SrcLoc.Default__PsLoc
skip SrcLoc.Default__BufSpan

# GHC 9.10: BufSpan has two fields but hs-to-rocq drops the second one (UNPACK issue)
redefine Inductive SrcLoc.BufSpan : Type := | Mk_BufSpan (bufSpanStart : BufPos) (bufSpanEnd : BufPos) : BufSpan.
order SrcLoc.BufPos SrcLoc.BufSpan

# orderings
order SrcLoc.Eq___RealSrcLoc SrcLoc.Ord__RealSrcLoc_min SrcLoc.Ord__RealSrcLoc_max SrcLoc.Ord__RealSrcLoc SrcLoc.cmpSrcLoc  SrcLoc.Ord__SrcLoc_min SrcLoc.Ord__SrcLoc_max SrcLoc.Eq___SrcLoc SrcLoc.Ord__SrcLoc

