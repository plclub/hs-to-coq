redefine Definition SrcLoc.Ord__RealSrcSpan_compare : RealSrcSpan -> RealSrcSpan -> comparison := fun a b => let 'RealSrcSpan' fa la ca la2 ca2 := a in let 'RealSrcSpan' fb lb cb lb2 cb2 := b in match Ord__RealSrcLoc_compare (ASrcLoc fa la ca) (ASrcLoc fb lb cb) with | Eq => Ord__RealSrcLoc_compare (ASrcLoc fa la2 ca2) (ASrcLoc fb lb2 cb2) | x => x end.
