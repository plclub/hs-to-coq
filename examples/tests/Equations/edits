# halve uses by-wf termination with a measure
add Equations Fixpoint Equations.toNatural (n : N) : nat := match n with | Z => 0 | S m => Datatypes.S (Equations.toNatural m) end.
termination Equations.halve {measure (Equations.toNatural arg_0__)}
order Equations.toNatural Equations.halve

