redefine Definition Data.Monoid.Functor__First_op_zlzd__ : forall {a : Type}, forall {b : Type}, a -> First b -> First a := fun {a} {b} x y => match y with | Mk_First z => Mk_First (x GHC.Base.<$ z) end.

redefine Definition Data.Monoid.Applicative__First_liftA2 : forall {a : Type}, forall {b : Type}, forall {c : Type}, (a -> b -> c) -> First a -> First b -> First c := fun {a} {b} {c} g x y => match x, y with | Mk_First x', Mk_First y' => Mk_First (GHC.Base.liftA2 g x' y') end.

