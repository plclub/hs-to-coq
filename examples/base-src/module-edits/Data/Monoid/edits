# Ap has poly-kinded f in Haskell (forall k. (k -> Type) -> k -> Type)
# Coq can't infer the kind, so we fix it to Type -> Type
redefine Inductive Data.Monoid.Ap (f : Type -> Type) (a : Type) : Type := | Mk_Ap (getAp : f a) : Ap f a.



