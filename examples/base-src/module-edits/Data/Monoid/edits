# Fix ordering: Functor must come before Applicative, Applicative before Monad
order Data.Monoid.Functor__Ap Data.Monoid.Applicative__Ap Data.Monoid.Monad__Ap Data.Monoid.MonadFail__Ap
order Data.Monoid.Functor__Last Data.Monoid.Applicative__Last Data.Monoid.Monad__Last
order Data.Monoid.Functor__First Data.Monoid.Applicative__First Data.Monoid.Monad__First
