# Ap has poly-kinded f in Haskell (forall k. (k -> Type) -> k -> Type)
# Coq can't infer the kind, so we fix it to Type -> Type
redefine Inductive Data.Monoid.Ap (f : Type -> Type) (a : Type) : Type := | Mk_Ap (getAp : f a) : Ap f a.

# GHC.Prim.coerce on typeclass methods causes Coq typeclass resolution loops
# for Ap, Last, First newtypes. Replace with explicit wrap/unwrap.

# Ap instances (wrapping f a)
redefine Definition Data.Monoid.Functor__Ap_fmap {inst_f : Type -> Type} `{GHC.Base.Functor inst_f} : forall {a : Type}, forall {b : Type}, (a -> b) -> Ap inst_f a -> Ap inst_f b := fun {a} {b} g x => match x with | Mk_Ap y => Mk_Ap (GHC.Base.fmap g y) end.

redefine Definition Data.Monoid.Functor__Ap_op_zlzd__ {inst_f : Type -> Type} `{GHC.Base.Functor inst_f} : forall {a : Type}, forall {b : Type}, a -> Ap inst_f b -> Ap inst_f a := fun {a} {b} x y => match y with | Mk_Ap z => Mk_Ap (x GHC.Base.<$ z) end.

redefine Definition Data.Monoid.Applicative__Ap_liftA2 {inst_f : Type -> Type} `{GHC.Base.Applicative inst_f} : forall {a : Type}, forall {b : Type}, forall {c : Type}, (a -> b -> c) -> Ap inst_f a -> Ap inst_f b -> Ap inst_f c := fun {a} {b} {c} g x y => match x, y with | Mk_Ap x', Mk_Ap y' => Mk_Ap (GHC.Base.liftA2 g x' y') end.

redefine Definition Data.Monoid.Applicative__Ap_op_zlztzg__ {inst_f : Type -> Type} `{GHC.Base.Applicative inst_f} : forall {a : Type}, forall {b : Type}, Ap inst_f (a -> b) -> Ap inst_f a -> Ap inst_f b := fun {a} {b} g x => match g, x with | Mk_Ap g', Mk_Ap x' => Mk_Ap (g' GHC.Base.<*> x') end.

redefine Definition Data.Monoid.Applicative__Ap_op_ztzg__ {inst_f : Type -> Type} `{GHC.Base.Applicative inst_f} : forall {a : Type}, forall {b : Type}, Ap inst_f a -> Ap inst_f b -> Ap inst_f b := fun {a} {b} x y => match x, y with | Mk_Ap x', Mk_Ap y' => Mk_Ap (x' GHC.Base.*> y') end.

redefine Definition Data.Monoid.Applicative__Ap_pure {inst_f : Type -> Type} `{GHC.Base.Applicative inst_f} : forall {a : Type}, a -> Ap inst_f a := fun {a} x => Mk_Ap (GHC.Base.pure x).

redefine Definition Data.Monoid.Monad__Ap_op_zgzg__ {inst_f : Type -> Type} `{GHC.Base.Monad inst_f} : forall {a : Type}, forall {b : Type}, Ap inst_f a -> Ap inst_f b -> Ap inst_f b := fun {a} {b} x y => match x, y with | Mk_Ap x', Mk_Ap y' => Mk_Ap (x' GHC.Base.>> y') end.

redefine Definition Data.Monoid.Monad__Ap_op_zgzgze__ {inst_f : Type -> Type} `{GHC.Base.Monad inst_f} : forall {a : Type}, forall {b : Type}, Ap inst_f a -> (a -> Ap inst_f b) -> Ap inst_f b := fun {a} {b} x k => match x with | Mk_Ap x' => Mk_Ap (x' GHC.Base.>>= (fun v => match k v with | Mk_Ap y => y end)) end.

redefine Definition Data.Monoid.Monad__Ap_return_ {inst_f : Type -> Type} `{GHC.Base.Monad inst_f} : forall {a : Type}, a -> Ap inst_f a := fun {a} x => Mk_Ap (GHC.Base.return_ x).

redefine Definition Data.Monoid.MonadFail__Ap_fail {inst_f : Type -> Type} `{Control.Monad.Fail.MonadFail inst_f} : forall {a : Type}, GHC.Base.String -> Ap inst_f a := fun {a} s => Mk_Ap (Control.Monad.Fail.fail s).

# Last instances (wrapping option a)
redefine Definition Data.Monoid.Functor__Last_fmap : forall {a : Type}, forall {b : Type}, (a -> b) -> Last a -> Last b := fun {a} {b} g x => match x with | Mk_Last y => Mk_Last (GHC.Base.fmap g y) end.

redefine Definition Data.Monoid.Functor__Last_op_zlzd__ : forall {a : Type}, forall {b : Type}, a -> Last b -> Last a := fun {a} {b} x y => match y with | Mk_Last z => Mk_Last (x GHC.Base.<$ z) end.

redefine Definition Data.Monoid.Applicative__Last_liftA2 : forall {a : Type}, forall {b : Type}, forall {c : Type}, (a -> b -> c) -> Last a -> Last b -> Last c := fun {a} {b} {c} g x y => match x, y with | Mk_Last x', Mk_Last y' => Mk_Last (GHC.Base.liftA2 g x' y') end.

redefine Definition Data.Monoid.Applicative__Last_op_zlztzg__ : forall {a : Type}, forall {b : Type}, Last (a -> b) -> Last a -> Last b := fun {a} {b} g x => match g, x with | Mk_Last g', Mk_Last x' => Mk_Last (g' GHC.Base.<*> x') end.

redefine Definition Data.Monoid.Applicative__Last_op_ztzg__ : forall {a : Type}, forall {b : Type}, Last a -> Last b -> Last b := fun {a} {b} x y => match x, y with | Mk_Last x', Mk_Last y' => Mk_Last (x' GHC.Base.*> y') end.

redefine Definition Data.Monoid.Applicative__Last_pure : forall {a : Type}, a -> Last a := fun {a} x => Mk_Last (GHC.Base.pure x).

redefine Definition Data.Monoid.Monad__Last_op_zgzg__ : forall {a : Type}, forall {b : Type}, Last a -> Last b -> Last b := fun {a} {b} x y => match x, y with | Mk_Last x', Mk_Last y' => Mk_Last (x' GHC.Base.>> y') end.

redefine Definition Data.Monoid.Monad__Last_op_zgzgze__ : forall {a : Type}, forall {b : Type}, Last a -> (a -> Last b) -> Last b := fun {a} {b} x k => match x with | Mk_Last x' => Mk_Last (x' GHC.Base.>>= (fun v => match k v with | Mk_Last y => y end)) end.

redefine Definition Data.Monoid.Monad__Last_return_ : forall {a : Type}, a -> Last a := fun {a} x => Mk_Last (GHC.Base.return_ x).

