# GHC 9.10: Down reverses min/max but the generated code creates mutual
# recursion between Ord__Down_min and Ord__Down_max. Redefine to use
# underlying Ord operations directly.
redefine Local Definition Data.Ord.Ord__Down_min {inst_a : Type} `{GHC.Base.Ord inst_a}
   : Down inst_a -> Down inst_a -> Down inst_a :=
  fun arg_0__ arg_1__ =>
    match arg_0__, arg_1__ with
    | Mk_Down x, Mk_Down y => Mk_Down (GHC.Base.max x y)
    end.

redefine Local Definition Data.Ord.Ord__Down_max {inst_a : Type} `{GHC.Base.Ord inst_a}
   : Down inst_a -> Down inst_a -> Down inst_a :=
  fun arg_0__ arg_1__ =>
    match arg_0__, arg_1__ with
    | Mk_Down x, Mk_Down y => Mk_Down (GHC.Base.min x y)
    end.


