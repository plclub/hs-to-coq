redefine Definition Data.Set.Internal.fromAscList {a : Type} `{GHC.Base.Eq_ a}
   : list a -> Set_ a :=
  fun xs => fromDistinctAscList (combineEq xs).

redefine Definition Data.Set.Internal.fromDescList {a : Type} `{GHC.Base.Eq_ a}
   : list a -> Set_ a :=
  fun xs => fromDistinctDescList (combineEq xs).

